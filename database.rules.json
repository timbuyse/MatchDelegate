{
  "rules": {

    "teams": {
      // Eigenaar mag alle ploegen lezen voor het globaal gebruikersoverzicht.
      ".read": "auth != null && root.child('owner').val() === auth.uid",

      "$teamId": {

        // Lezen: leden van de ploeg, de eigenaar (globaal overzicht), of de clubbeheerder van de
        // club waartoe deze ploeg behoort (fase 2d).
        ".read": "auth != null && (root.child('teams/' + $teamId + '/members/' + auth.uid).exists() || root.child('owner').val() === auth.uid || root.child('clubs/' + root.child('teams/' + $teamId + '/info/clubId').val() + '/admins/' + auth.uid).exists())",

        // Nieuwe ploeg aanmaken: team bestaat nog niet + gebruiker zet zichzelf als admin
        //   EN is eigenaar of goedgekeurd beheerder; OF de clubbeheerder maakt ze aan in zijn club (fase 2d).
        // Bestaande ploeg aanpassen: bestaande admin, eigenaar, of clubbeheerder van de club (fase 2d).
        // Verwijderen: eigenaar (alle teams) of goedgekeurde beheerder die ook maker is (createdBy) —
        //   de clubbeheerder mag NIET hard verwijderen (enkel archiveren = een gewone aanpassing).
        ".write": "auth != null && (root.child('owner').val() === auth.uid || (!data.exists() && newData.child('members').child(auth.uid).val() === 'admin' && root.child('approvedAdmins/' + auth.uid).exists()) || (!data.exists() && root.child('clubs/' + newData.child('info/clubId').val() + '/admins/' + auth.uid).exists()) || (data.exists() && newData.exists() && root.child('teams/' + $teamId + '/members/' + auth.uid).val() === 'admin') || (data.exists() && newData.exists() && root.child('clubs/' + root.child('teams/' + $teamId + '/info/clubId').val() + '/admins/' + auth.uid).exists()) || (data.exists() && !newData.exists() && root.child('approvedAdmins/' + auth.uid).exists() && data.child('info/createdBy').val() === auth.uid))",

        "members": {
          // Admin (of de clubbeheerder van de club, fase 2d) mag leden beheren.
          ".write": "auth != null && (root.child('teams/' + $teamId + '/members/' + auth.uid).val() === 'admin' || root.child('clubs/' + root.child('teams/' + $teamId + '/info/clubId').val() + '/admins/' + auth.uid).exists())",

          "$memberId": {
            // Een gebruiker mag ALTIJD zijn eigen lidmaatschap lezen (ook vóór hij lid is),
            // zodat hij bij het vervoegen kan checken of hij al lid is.
            ".read": "auth != null && $memberId === auth.uid",

            // Nieuw lid mag zichzelf toevoegen als viewer (via uitnodiging); een lid mag zijn
            // eigen lidmaatschap altijd weer verwijderen (account verwijderen/ploeg verlaten);
            // beheerder OF de clubbeheerder van de club mag de rol van elk lid aanpassen (promote/demote).
            ".write": "auth != null && (($memberId === auth.uid && !data.exists() && newData.val() === 'viewer') || ($memberId === auth.uid && !newData.exists()) || root.child('teams/' + $teamId + '/members/' + auth.uid).val() === 'admin' || root.child('clubs/' + root.child('teams/' + $teamId + '/info/clubId').val() + '/admins/' + auth.uid).exists())"
          }
        },

        "info": {
          "clubId": {
            // De clubId van een ploeg ligt vast na aanmaken (fase 2d hardening): enkel de eigenaar
            // mag ze wijzigen (= een ploeg naar een andere club verplaatsen). Een ploegbeheerder
            // kan zo het clubtoezicht niet afschudden of een ploeg in een vreemde club planten;
            // bij aanmaken moet de maker clubbeheerder zijn van de opgegeven club.
            ".validate": "root.child('owner').val() === auth.uid || (data.exists() && newData.val() === data.val()) || (!data.exists() && root.child('clubs/' + newData.val() + '/admins/' + auth.uid).exists())"
          }
        }
      }
    },

    "memberInfo": {
      // Eigenaar mag alle memberInfo lezen voor het globaal gebruikersoverzicht.
      ".read": "auth != null && root.child('owner').val() === auth.uid",

      "$teamId": {
        // Beheerder van de ploeg leest de volledige ledenlijst, de eigenaar, of de clubbeheerder
        // van de club waartoe deze ploeg behoort (fase 2d).
        ".read":  "auth != null && (root.child('teams/' + $teamId + '/members/' + auth.uid).val() === 'admin' || root.child('owner').val() === auth.uid || root.child('clubs/' + root.child('teams/' + $teamId + '/info/clubId').val() + '/admins/' + auth.uid).exists())",
        ".write": "auth != null && (root.child('owner').val() === auth.uid || root.child('teams/' + $teamId + '/members/' + auth.uid).val() === 'admin' || root.child('clubs/' + root.child('teams/' + $teamId + '/info/clubId').val() + '/admins/' + auth.uid).exists())",
        "$memberId": {
          // Elk lid leest/schrijft enkel zijn eigen info, en enkel als hij lid is.
          ".read":  "auth != null && $memberId === auth.uid",
          ".write": "auth != null && $memberId === auth.uid && root.child('teams/' + $teamId + '/members/' + auth.uid).exists()"
        }
      }
    },

    "users": {
      "$userId": {
        ".read":  "auth != null && (auth.uid === $userId || root.child('owner').val() === auth.uid)",
        ".write": "auth != null && auth.uid === $userId",
        "clubs": {
          // Clubmodel (fase 3): de gebruiker beheert zijn eigen club-index, en de app-eigenaar mag
          // ze ook schrijven om iemand als clubbeheerder aan te stellen (omgekeerde index).
          ".write": "auth != null && (auth.uid === $userId || root.child('owner').val() === auth.uid)"
        },
        "teams": {
          // De app-eigenaar mag de omgekeerde ploeg-index van een gebruiker schrijven om rechtstreeks
          // een ploegbeheerder aan te stellen (fase 2d). De gebruiker zelf schrijft ze sowieso al.
          ".write": "auth != null && (auth.uid === $userId || root.child('owner').val() === auth.uid)"
        }
      }
    },

    "owner": {
      // Iedereen die ingelogd is kan lezen wie de eigenaar is.
      // Schrijven kan enkel zolang er nog GEEN eigenaar is (eenmalig claimen).
      ".read":  "auth != null",
      ".write": "auth != null && !data.exists()"
    },

    "approvedAdmins": {
      // Enkel de eigenaar beheert de lijst van goedgekeurde beheerders.
      ".read":  "auth != null && root.child('owner').val() === auth.uid",
      ".write": "auth != null && root.child('owner').val() === auth.uid",
      "$uid": {
        // Elke gebruiker mag zijn eigen goedkeuringsstatus lezen.
        ".read": "auth != null && auth.uid === $uid",
        // Een gebruiker mag zijn EIGEN entry enkel VERWIJDEREN (niet aanmaken/wijzigen) —
        // nodig bij accountverwijdering, anders blijft naam+e-mail hier permanent staan
        // gekoppeld aan een uid die niet meer bestaat.
        ".write": "auth != null && auth.uid === $uid && !newData.exists()"
      }
    },

    "adminRequests": {
      // Eigenaar leest/beheert alle aanvragen.
      ".read":  "auth != null && root.child('owner').val() === auth.uid",
      ".write": "auth != null && root.child('owner').val() === auth.uid",
      "$uid": {
        // Een gebruiker mag enkel zijn eigen aanvraag lezen/schrijven.
        ".read":  "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    "invites": {
      "$token": {
        ".read": "auth != null",
        // Aanmaken: teamadmin van de betrokken ploeg (of eigenaar). Bij het overschrijven
        // van een BESTAAND token moet je bovendien ook admin zijn van de ploeg waar dat
        // token al aan toebehoorde — anders zou een admin van ploeg A het token van ploeg B
        // kunnen kapen door het te overschrijven met teamId=A (enkel A's adminschap werd
        // dan gecontroleerd, nooit B's). Verwijderen (bv. bij regenereren van de code): de
        // oorspronkelijke maker OF elke huidige teamadmin van die ploeg — niet enkel wie
        // het token ooit zelf aanmaakte.
        ".write": "auth != null && (root.child('owner').val() === auth.uid || (newData.exists() && root.child('teams/' + newData.child('teamId').val() + '/members/' + auth.uid).val() === 'admin' && (!data.exists() || root.child('teams/' + data.child('teamId').val() + '/members/' + auth.uid).val() === 'admin')) || (!newData.exists() && (data.child('createdBy').val() === auth.uid || root.child('teams/' + data.child('teamId').val() + '/members/' + auth.uid).val() === 'admin')) || (newData.exists() && root.child('clubs/' + root.child('teams/' + newData.child('teamId').val() + '/info/clubId').val() + '/admins/' + auth.uid).exists() && (!data.exists() || root.child('clubs/' + root.child('teams/' + data.child('teamId').val() + '/info/clubId').val() + '/admins/' + auth.uid).exists())) || (!newData.exists() && root.child('clubs/' + root.child('teams/' + data.child('teamId').val() + '/info/clubId').val() + '/admins/' + auth.uid).exists()))"
      }
    },

    "maintenance": {
      // Iedereen die ingelogd is mag lezen (om onderhoudsmodus te detecteren).
      // Enkel de eigenaar mag schrijven.
      ".read":  "auth != null",
      ".write": "auth != null && root.child('owner').val() === auth.uid"
    },

    "rejectedAdmins": {
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",
        ".write": "auth != null && (root.child('owner').val() === auth.uid || auth.uid === $uid)"
      }
    },

    "teamAdminRequests": {
      "$teamId": {
        ".read": "auth != null && (root.child('owner').val() === auth.uid || root.child('teams/' + $teamId + '/members/' + auth.uid).val() === 'admin')",
        ".write": "auth != null && (root.child('owner').val() === auth.uid || root.child('teams/' + $teamId + '/members/' + auth.uid).val() === 'admin')",
        "$uid": {
          ".read": "auth != null && auth.uid === $uid",
          ".write": "auth != null && auth.uid === $uid && root.child('teams/' + $teamId + '/members/' + auth.uid).val() === 'viewer'"
        }
      }
    },

    "teamNotes": {
      // Notities (wedstrijd + per speler) apart van "matches" gehouden zodat kijkers/gasten
      // ze nooit kunnen lezen, ook niet rechtstreeks via Firebase (in tegenstelling tot
      // teams/$teamId/matches, dat voor elk teamlid leesbaar is). Toegang: beheerder van de ploeg,
      // de eigenaar, of de clubbeheerder van de club waartoe de ploeg behoort (fase 2d schijf 3).
      "$teamId": {
        ".read":  "auth != null && (root.child('teams/' + $teamId + '/members/' + auth.uid).val() === 'admin' || root.child('owner').val() === auth.uid || root.child('clubs/' + root.child('teams/' + $teamId + '/info/clubId').val() + '/admins/' + auth.uid).exists())",
        ".write": "auth != null && (root.child('teams/' + $teamId + '/members/' + auth.uid).val() === 'admin' || root.child('owner').val() === auth.uid || root.child('clubs/' + root.child('teams/' + $teamId + '/info/clubId').val() + '/admins/' + auth.uid).exists())"
      }
    },

    "deletedMatches": {
      // Backup van een verwijderde wedstrijd (vangnet tegen abusievelijk verwijderen).
      // Zelfde rechten als teamNotes: beheerder(s) van die ploeg, de eigenaar, of de clubbeheerder.
      "$teamId": {
        ".read":  "auth != null && (root.child('teams/' + $teamId + '/members/' + auth.uid).val() === 'admin' || root.child('owner').val() === auth.uid || root.child('clubs/' + root.child('teams/' + $teamId + '/info/clubId').val() + '/admins/' + auth.uid).exists())",
        ".write": "auth != null && (root.child('teams/' + $teamId + '/members/' + auth.uid).val() === 'admin' || root.child('owner').val() === auth.uid || root.child('clubs/' + root.child('teams/' + $teamId + '/info/clubId').val() + '/admins/' + auth.uid).exists())"
      }
    },

    "deletedTeams": {
      // Enkel eigenaar mag alle backups lezen en herstellen.
      ".read":  "auth != null && root.child('owner').val() === auth.uid",
      ".write": "auth != null && root.child('owner').val() === auth.uid",
      "$teamId": {
        // Beheerder mag backup schrijven van zijn eigen team bij verwijderen.
        ".write": "auth != null && (root.child('owner').val() === auth.uid || root.child('teams/' + $teamId + '/members/' + auth.uid).val() === 'admin')"
      }
    },

    "usersByEmail": {
      // E-mail->uid index (fase 3) zodat de eigenaar een clubbeheerder op e-mailadres kan
      // aanstellen, ook voor iemand die (nog) geen ploeg vervoegd heeft. Enkel de eigenaar leest
      // de volledige index. Elke gebruiker schrijft ENKEL zijn eigen entry, en enkel met zijn
      // eigen (door Firebase geverifieerde) e-mailadres — zo kan niemand andermans e-mail claimen.
      // Zelf verwijderen (bij accountverwijdering) mag ook.
      ".read": "auth != null && root.child('owner').val() === auth.uid",
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid && (!newData.exists() || newData.child('email').val() === auth.token.email)"
      }
    },

    "clubs": {
      // FASE 1 (clubmodel-fundament). Een club groepeert meerdere ploegen. Voorlopig schrijft
      // ENKEL de app-eigenaar (die maakt clubs aan en stelt clubbeheerders aan). Clubbeheerders
      // mogen hun eigen club al lezen; hun schrijfrechten (ploegen beheren binnen de club) komen
      // in fase 2 met fijnmazige sub-rules zodat een clubbeheerder niet zijn eigen admins-lijst
      // kan bewerken.
      // Eigenaar leest alle clubs voor het globaal overzicht.
      ".read":  "auth != null && root.child('owner').val() === auth.uid",
      "$clubId": {
        // Lezen: clubbeheerder van deze club, of de eigenaar.
        ".read":  "auth != null && (root.child('clubs/' + $clubId + '/admins/' + auth.uid).exists() || root.child('owner').val() === auth.uid)",
        // Schrijven op clubniveau (info + admins): enkel de eigenaar. Zo kan een clubbeheerder
        // zichzelf niet uit de admins verwijderen of anderen toevoegen.
        ".write": "auth != null && root.child('owner').val() === auth.uid",
        "teams": {
          // De ploeg-index binnen de club mag ook door de clubbeheerder beheerd worden (fase 2d),
          // zodat hij ploegen kan aanmaken/registreren in zijn club. (Niet info of admins.)
          ".write": "auth != null && (root.child('owner').val() === auth.uid || root.child('clubs/' + $clubId + '/admins/' + auth.uid).exists())"
        }
      }
    },

    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
