{
  "rules": {

    "teams": {
      "$teamId": {

        // Lezen: leden van de ploeg
        ".read": "auth != null && root.child('teams/' + $teamId + '/members/' + auth.uid).exists()",

        // Nieuwe ploeg aanmaken: team bestaat nog niet + gebruiker zet zichzelf als admin
        // Bestaande ploeg aanpassen: enkel bestaande admin
        ".write": "auth != null && ((!data.exists() && newData.child('members').child(auth.uid).val() === 'admin') || root.child('teams/' + $teamId + '/members/' + auth.uid).val() === 'admin')",

        "members": {
          // Admin mag leden beheren
          ".write": "auth != null && root.child('teams/' + $teamId + '/members/' + auth.uid).val() === 'admin'",

          "$memberId": {
            // Een gebruiker mag ALTIJD zijn eigen lidmaatschap lezen (ook vóór hij lid is),
            // zodat hij bij het vervoegen kan checken of hij al lid is.
            ".read": "auth != null && $memberId === auth.uid",

            // Nieuw lid mag zichzelf toevoegen als viewer (via uitnodiging)
            ".write": "auth != null && $memberId === auth.uid && !data.exists() && newData.val() === 'viewer'"
          }
        }
      }
    },

    "memberInfo": {
      "$teamId": {
        // Enkel de beheerder van de ploeg leest de volledige ledenlijst (naam + e-mail).
        // De beheerder mag het knooppunt ook opruimen bij verwijderen van de ploeg.
        ".read":  "auth != null && root.child('teams/' + $teamId + '/members/' + auth.uid).val() === 'admin'",
        ".write": "auth != null && root.child('teams/' + $teamId + '/members/' + auth.uid).val() === 'admin'",
        "$memberId": {
          // Elk lid leest/schrijft enkel zijn eigen info, en enkel als hij lid is.
          ".read":  "auth != null && $memberId === auth.uid",
          ".write": "auth != null && $memberId === auth.uid && root.child('teams/' + $teamId + '/members/' + auth.uid).exists()"
        }
      }
    },

    "users": {
      "$userId": {
        ".read":  "auth != null && auth.uid === $userId",
        ".write": "auth != null && auth.uid === $userId"
      }
    },

    "invites": {
      "$token": {
        ".read": "auth != null",
        ".write": "auth != null && ((newData.exists() && root.child('teams/' + newData.child('teamId').val() + '/members/' + auth.uid).val() === 'admin') || (!newData.exists() && data.child('createdBy').val() === auth.uid))"
      }
    },

    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
