{
  "rules": {

    "teams": {
      // Eigenaar mag alle ploegen lezen voor het globaal gebruikersoverzicht.
      ".read": "auth != null && root.child('owner').val() === auth.uid",

      "$teamId": {

        // Lezen: leden van de ploeg, of de eigenaar (globaal overzicht)
        ".read": "auth != null && (root.child('teams/' + $teamId + '/members/' + auth.uid).exists() || root.child('owner').val() === auth.uid)",

        // Nieuwe ploeg aanmaken: team bestaat nog niet + gebruiker zet zichzelf als admin
        //   EN is eigenaar of goedgekeurd beheerder.
        // Bestaande ploeg aanpassen: bestaande admin of eigenaar.
        // Aanmaken: goedgekeurde beheerder zet zichzelf als admin.
        // Aanpassen: bestaande admin of eigenaar.
        // Verwijderen: eigenaar (alle teams) of goedgekeurde beheerder die ook maker is (createdBy).
        ".write": "auth != null && (root.child('owner').val() === auth.uid || (!data.exists() && newData.child('members').child(auth.uid).val() === 'admin' && root.child('approvedAdmins/' + auth.uid).exists()) || (data.exists() && newData.exists() && root.child('teams/' + $teamId + '/members/' + auth.uid).val() === 'admin') || (data.exists() && !newData.exists() && root.child('approvedAdmins/' + auth.uid).exists() && data.child('info/createdBy').val() === auth.uid))",

        "members": {
          // Admin mag leden beheren
          ".write": "auth != null && root.child('teams/' + $teamId + '/members/' + auth.uid).val() === 'admin'",

          "$memberId": {
            // Een gebruiker mag ALTIJD zijn eigen lidmaatschap lezen (ook vóór hij lid is),
            // zodat hij bij het vervoegen kan checken of hij al lid is.
            ".read": "auth != null && $memberId === auth.uid",

            // Nieuw lid mag zichzelf toevoegen als viewer (via uitnodiging); een lid mag zijn
            // eigen lidmaatschap altijd weer verwijderen (account verwijderen/ploeg verlaten);
            // beheerder mag altijd de rol van elk lid aanpassen (promote/demote).
            ".write": "auth != null && (($memberId === auth.uid && !data.exists() && newData.val() === 'viewer') || ($memberId === auth.uid && !newData.exists()) || root.child('teams/' + $teamId + '/members/' + auth.uid).val() === 'admin')"
          }
        }
      }
    },

    "memberInfo": {
      // Eigenaar mag alle memberInfo lezen voor het globaal gebruikersoverzicht.
      ".read": "auth != null && root.child('owner').val() === auth.uid",

      "$teamId": {
        // Beheerder van de ploeg leest de volledige ledenlijst, of de eigenaar (globaal overzicht).
        ".read":  "auth != null && (root.child('teams/' + $teamId + '/members/' + auth.uid).val() === 'admin' || root.child('owner').val() === auth.uid)",
        ".write": "auth != null && (root.child('owner').val() === auth.uid || root.child('teams/' + $teamId + '/members/' + auth.uid).val() === 'admin')",
        "$memberId": {
          // Elk lid leest/schrijft enkel zijn eigen info, en enkel als hij lid is.
          ".read":  "auth != null && $memberId === auth.uid",
          ".write": "auth != null && $memberId === auth.uid && root.child('teams/' + $teamId + '/members/' + auth.uid).exists()"
        }
      }
    },

    "users": {
      "$userId": {
        ".read":  "auth != null && (auth.uid === $userId || root.child('owner').val() === auth.uid)",
        ".write": "auth != null && auth.uid === $userId"
      }
    },

    "owner": {
      // Iedereen die ingelogd is kan lezen wie de eigenaar is.
      // Schrijven kan enkel zolang er nog GEEN eigenaar is (eenmalig claimen).
      ".read":  "auth != null",
      ".write": "auth != null && !data.exists()"
    },

    "approvedAdmins": {
      // Enkel de eigenaar beheert de lijst van goedgekeurde beheerders.
      ".read":  "auth != null && root.child('owner').val() === auth.uid",
      ".write": "auth != null && root.child('owner').val() === auth.uid",
      "$uid": {
        // Elke gebruiker mag zijn eigen goedkeuringsstatus lezen.
        ".read": "auth != null && auth.uid === $uid",
        // Een gebruiker mag zijn EIGEN entry enkel VERWIJDEREN (niet aanmaken/wijzigen) —
        // nodig bij accountverwijdering, anders blijft naam+e-mail hier permanent staan
        // gekoppeld aan een uid die niet meer bestaat.
        ".write": "auth != null && auth.uid === $uid && !newData.exists()"
      }
    },

    "adminRequests": {
      // Eigenaar leest/beheert alle aanvragen.
      ".read":  "auth != null && root.child('owner').val() === auth.uid",
      ".write": "auth != null && root.child('owner').val() === auth.uid",
      "$uid": {
        // Een gebruiker mag enkel zijn eigen aanvraag lezen/schrijven.
        ".read":  "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    "invites": {
      "$token": {
        ".read": "auth != null",
        // Aanmaken: teamadmin van de betrokken ploeg (of eigenaar). Bij het overschrijven
        // van een BESTAAND token moet je bovendien ook admin zijn van de ploeg waar dat
        // token al aan toebehoorde — anders zou een admin van ploeg A het token van ploeg B
        // kunnen kapen door het te overschrijven met teamId=A (enkel A's adminschap werd
        // dan gecontroleerd, nooit B's). Verwijderen (bv. bij regenereren van de code): de
        // oorspronkelijke maker OF elke huidige teamadmin van die ploeg — niet enkel wie
        // het token ooit zelf aanmaakte.
        ".write": "auth != null && (root.child('owner').val() === auth.uid || (newData.exists() && root.child('teams/' + newData.child('teamId').val() + '/members/' + auth.uid).val() === 'admin' && (!data.exists() || root.child('teams/' + data.child('teamId').val() + '/members/' + auth.uid).val() === 'admin')) || (!newData.exists() && (data.child('createdBy').val() === auth.uid || root.child('teams/' + data.child('teamId').val() + '/members/' + auth.uid).val() === 'admin')))"
      }
    },

    "maintenance": {
      // Iedereen die ingelogd is mag lezen (om onderhoudsmodus te detecteren).
      // Enkel de eigenaar mag schrijven.
      ".read":  "auth != null",
      ".write": "auth != null && root.child('owner').val() === auth.uid"
    },

    "rejectedAdmins": {
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",
        ".write": "auth != null && (root.child('owner').val() === auth.uid || auth.uid === $uid)"
      }
    },

    "teamAdminRequests": {
      "$teamId": {
        ".read": "auth != null && (root.child('owner').val() === auth.uid || root.child('teams/' + $teamId + '/members/' + auth.uid).val() === 'admin')",
        ".write": "auth != null && (root.child('owner').val() === auth.uid || root.child('teams/' + $teamId + '/members/' + auth.uid).val() === 'admin')",
        "$uid": {
          ".read": "auth != null && auth.uid === $uid",
          ".write": "auth != null && auth.uid === $uid && root.child('teams/' + $teamId + '/members/' + auth.uid).val() === 'viewer'"
        }
      }
    },

    "teamNotes": {
      // Notities (wedstrijd + per speler) apart van "matches" gehouden zodat kijkers/gasten
      // ze nooit kunnen lezen, ook niet rechtstreeks via Firebase (in tegenstelling tot
      // teams/$teamId/matches, dat voor elk teamlid leesbaar is).
      "$teamId": {
        ".read":  "auth != null && (root.child('teams/' + $teamId + '/members/' + auth.uid).val() === 'admin' || root.child('owner').val() === auth.uid)",
        ".write": "auth != null && (root.child('teams/' + $teamId + '/members/' + auth.uid).val() === 'admin' || root.child('owner').val() === auth.uid)"
      }
    },

    "deletedMatches": {
      // Backup van een verwijderde wedstrijd (vangnet tegen abusievelijk verwijderen).
      // Zelfde rechten als teamNotes: enkel de beheerder(s) van die ploeg, of de eigenaar.
      "$teamId": {
        ".read":  "auth != null && (root.child('teams/' + $teamId + '/members/' + auth.uid).val() === 'admin' || root.child('owner').val() === auth.uid)",
        ".write": "auth != null && (root.child('teams/' + $teamId + '/members/' + auth.uid).val() === 'admin' || root.child('owner').val() === auth.uid)"
      }
    },

    "deletedTeams": {
      // Enkel eigenaar mag alle backups lezen en herstellen.
      ".read":  "auth != null && root.child('owner').val() === auth.uid",
      ".write": "auth != null && root.child('owner').val() === auth.uid",
      "$teamId": {
        // Beheerder mag backup schrijven van zijn eigen team bij verwijderen.
        ".write": "auth != null && (root.child('owner').val() === auth.uid || root.child('teams/' + $teamId + '/members/' + auth.uid).val() === 'admin')"
      }
    },

    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
